# ─── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_CLASSIFIER_MODEL=llama-3.1-8b-instant

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# ─── Qdrant Cloud (production) ────────────────────────────────────────────────
# Leave QDRANT_URL empty to use local file-mode Qdrant instead (dev only).
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=healthcare_funds

# ─── Qdrant local fallback (dev only — ignored when QDRANT_URL is set) ────────
QDRANT_LOCAL_PATH=./vectorstore/qdrant_local

# ─── Retrieval ────────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=6

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_HOUR_IST=10

# ─── FastAPI ──────────────────────────────────────────────────────────────────
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8002
LOG_LEVEL=INFO
HF_HOME=/opt/huggingface

# ─── CORS (set on Railway once you know your Vercel URL) ─────────────────────
# Comma-separated list of additional allowed origins beyond localhost defaults.
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://healthfundiq.com

# ─── Frontend (set this in Vercel env, not locally) ──────────────────────────
# NEXT_PUBLIC_API_URL=https://your-railway-backend.up.railway.app
